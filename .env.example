# Frontend Environment Variables Example
# Copy this to .env.production and update with your actual values

# Backend API URL - Update with your Render deployment URL
VITE_API_BASE_URL=https://your-render-backend.onrender.com

# Firebase Configuration - Get from Firebase Console
# https://console.firebase.google.com/ → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
